# Web app environment variables.
# Set these in Vercel → Settings → Environment Variables (Production + Preview).
# The real value lives only in Vercel and is read server-side by api/quotes.js and
# api/history.js — it is NEVER exposed to the browser. Do not commit a real .env.

# CoinMarketCap Pro API key (required by the serverless functions)
CMC_API_KEY=
