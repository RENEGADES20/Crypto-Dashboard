# Publish ONLY the web app. Ignore everything else by default (whitelist).
# This protects local research material AND prevents secrets (e.g. the CMC key
# hardcoded in data/*.py) from ever being committed.
*

# --- Web app (allowed) ---
!index.html
!overview_assets.js
!.gitignore
!.nojekyll

# Vercel serverless API
!api/
!api/*.js

# Dashboard copies (HTML + JS only; no PDFs/DOCX inside)
!dashboard/
!dashboard/*.html
!dashboard/*.js

# --- Secrets: never publish, even if matched above ---
.env
.env.*
**/api.txt
**/tt_session.json
